# CY/Live Production Environment Variables
# Copy this to .env and fill in your actual values

# ==========================================
# N8N Configuration
# ==========================================
N8N_USER=admin
N8N_PASSWORD=your_secure_password_here
N8N_ENCRYPTION_KEY=your_32_character_encryption_key_here
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678
N8N_DB_PASSWORD=n8n_secure_db_password

# ==========================================
# MCP Server
# ==========================================
MCP_AUTH_TOKEN=your_mcp_auth_token_here

# ==========================================
# Database
# ==========================================
POSTGRES_PASSWORD=your_postgres_password_here
N8N_DB_PASSWORD=n8n_database_password
KEYCLOAK_DB_PASSWORD=keycloak_db_password

# ==========================================
# Redis
# ==========================================
REDIS_PASSWORD=your_redis_password_here

# ==========================================
# AI Services
# ==========================================
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_openai_key_here

# ==========================================
# OIDC / Keycloak
# ==========================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=your_keycloak_admin_password
KEYCLOAK_HOSTNAME=auth.yourdomain.com

# ==========================================
# Vault
# ==========================================
VAULT_TOKEN=your_vault_root_token

# ==========================================
# Monitoring
# ==========================================
GRAFANA_PASSWORD=your_grafana_password

# ==========================================
# Frontend (Next.js)
# ==========================================
NEXT_PUBLIC_N8N_URL=http://localhost:5678
NEXT_PUBLIC_MEDIAMTX_URL=http://localhost:8888
NEXT_PUBLIC_MCP_REGISTRY_URL=http://localhost:5679
NEXT_PUBLIC_API_URL=http://localhost:5678

# ==========================================
# MediaMTX
# ==========================================
MEDIAMTX_HOSTS=localhost,yourdomain.com
