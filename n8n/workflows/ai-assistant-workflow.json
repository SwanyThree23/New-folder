      "description": "Ask a question to Claude AI with context",
      "parameters": {
        "question": { "type": "string", "required": true },
        "context": { "type": "object" }
      }
    },
    "analyze_sentiment": {
      "name": "cylive_analyze_sentiment",
      "description": "Analyze sentiment of text using Claude",
      "parameters": {
        "text": { "type": "string", "required": true }
      }
    }
  },
