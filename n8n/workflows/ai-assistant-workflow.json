    }
  },
  "mcpTools": {
    "transcribe_audio": {
      "name": "cylive_transcribe_audio",
      "description": "Transcribe audio using OpenAI Whisper",
      "parameters": {
        "audioBase64": { "type": "string", "description": "Base64-encoded audio data" },
        "audioUrl": { "type": "string", "description": "URL to audio file" },
        "language": { "type": "string", "default": "en" }
      }
    },
    "summarize_text": {
      "name": "cylive_summarize_text",
