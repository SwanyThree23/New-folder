      ]
    },
    "Action Switch": {
      "main": [
        [{"node": "Whisper Transcription", "type": "main", "index": 0}],
        [{"node": "Claude Summarization", "type": "main", "index": 0}],
        [{"node": "Claude Q&A", "type": "main", "index": 0}],
        [{"node": "Claude Sentiment Analysis", "type": "main", "index": 0}]
      ]
    },
    "Whisper Transcription": {
      "main": [[{"node": "Process AI Response", "type": "main", "index": 0}]]
    },
    "Claude Summarization": {
      "main": [[{"node": "Process AI Response", "type": "main", "index": 0}]]
    },
    "Claude Q&A": {
      "main": [[{"node": "Process AI Response", "type": "main", "index": 0}]]
    },
    "Claude Sentiment Analysis": {
      "main": [[{"node": "Process AI Response", "type": "main", "index": 0}]]
    },
    "Process AI Response": {
      "main": [[{"node": "Log AI Usage", "type": "main", "index": 0}]]
